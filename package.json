{
  "name": "boundary-agent-firewall",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A deterministic content firewall for autonomous agents, metered with x402.",
  "license": "MIT",
  "engines": { "node": ">=22" },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "wallet:create": "tsx scripts/create-wallet.ts"
  },
  "dependencies": {
    "@coinbase/x402": "^2.1.0",
    "@x402/core": "^2.19.0",
    "@x402/evm": "^2.19.0",
    "@x402/express": "^2.19.0",
    "express": "^5.2.1",
    "helmet": "^8.3.0",
    "html-to-text": "^10.0.0",
    "viem": "^2.55.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/html-to-text": "^9.0.4",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.2.2",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
